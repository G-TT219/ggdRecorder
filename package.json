{
  "name": "ggdrecorder",
  "version": "1.0.0",
  "description": "A game recording application",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "vite",
    "dev-electron": "concurrently \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npm run dev\" \"cross-env NODE_ENV=development npm run start\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "keywords": [
    "game",
    "recording",
    "electron",
    "react"
  ],
  "author": "GTT",
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.0.0",
    "vite": "^4.0.0"
  },
  "dependencies": {
    "electron": "^39.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "ps-list": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.example.gamerecorder",
    "productName": "游戏录制器",
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
