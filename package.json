{
  "name": "ggdrecorder",
  "version": "1.0.5",
  "description": "A game recording application",
  "main": "dist-main/main/index.js",
  "homepage": "https://github.com/G-TT219/ggdRecorder",
  "author": {
    "name": "GTT",
    "email": "huausb159357@163.com"
  },
  "scripts": {
    "start": "electron-forge start",
    "dev": "vite",
    "dev-electron": "npm run build-main && cross-env NODE_ENV=development concurrently \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npm run dev\" \"electron-forge start\"",
    "build": "npm run build-main && vite build",
    "build-main": "tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "pack-app": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux deb",
    "dist:win-test": "npm run build && electron-builder --win && test.bat"
  },
  "keywords": [
    "game",
    "recording",
    "electron",
    "react"
  ],
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.0.0",
    "electron-builder": "^24.9.1",
    "electron-reloader": "^1.2.3",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^4.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "https-proxy-agent": "^9.0.0",
    "minizlib": "2.1.2",
    "ps-list": "^9.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tar": "^7.4.0",
    "undici": "^7.16.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "build": {
    "appId": "com.example.gamerecorder",
    "productName": "ggdRecord",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "recorder.ico"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "AudioVideo",
      "icon": "recorder.png",
      "maintainer": "GTT <huausb159357@163.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "installerIcon": "recorder.ico",
      "uninstallerIcon": "recorder.ico",
      "installerHeaderIcon": "recorder.ico",
      "shortcutName": "ggdRecord"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*",
      "recorder.ico"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ]
  }
}
